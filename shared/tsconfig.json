{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "This tsconfig is for IDE support only. shared/ has no own node_modules — it relies on the consuming project (View/, mobile_new/) for dependencies.",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": "."
  },
  "include": ["**/*.ts"]
}
